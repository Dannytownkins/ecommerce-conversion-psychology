<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Security-Policy" content="default-src 'none'; style-src 'unsafe-inline'; img-src data:; font-src data:;">
  <title>CRO Report — {{ENGAGEMENT_ID}}</title>
  <!-- FONT EMBED: Copy the entire contents of templates/font-embed.css into a <style> block here, BEFORE the design tokens below. -->
  <style>
    /* ============================================================
       DESIGN TOKENS — from components.html Section 1
       ============================================================ */
    :root {
      /* Surfaces (ascending elevation) */
      --bg-body: #0e0e10;
      --bg-surface: #141418;
      --bg-elevated: #1a1a1f;
      --bg-hover: #2e2e36;
      --bg-active: #3f3f46;

      /* Borders */
      --border-default: rgba(255,255,255,0.08);
      --border-strong: rgba(255,255,255,0.12);
      --border-emphasis: rgba(255,255,255,0.16);

      /* Text */
      --text-primary: #e4e4e7;
      --text-secondary: #a1a1aa;
      --text-tertiary: #71717a;
      --text-muted: #52525b;

      /* Severity colors */
      --severity-critical: #f87171;
      --severity-critical-bg: #2c1113;
      --severity-high: #fbbf24;
      --severity-high-bg: #2c1d0e;
      --severity-medium: #60a5fa;
      --severity-medium-bg: #0f1a2e;
      --severity-low: #a1a1aa;
      --severity-low-bg: #1a1a1f;

      /* Severity card borders */
      --border-critical: rgba(248,113,113,0.25);
      --border-high: rgba(251,191,36,0.20);
      --border-medium: rgba(96,165,250,0.20);
      --border-low: rgba(161,161,170,0.12);

      /* Evidence tier colors */
      --tier-gold: #fbbf24;
      --tier-gold-bg: #2c1d0e;
      --tier-silver: #a1a1aa;
      --tier-silver-bg: #1a1a1f;
      --tier-bronze: #cd7f32;
      --tier-bronze-bg: #2c1a0e;

      /* Typography */
      --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      --font-mono: 'JetBrains Mono', 'SF Mono', 'Fira Code', 'Consolas', monospace;
      --text-xs: 0.75rem;
      --text-sm: 0.8125rem;
      --text-base: 0.875rem;
      --text-lg: 1rem;
      --text-xl: 1.25rem;
      --text-2xl: 1.5rem;
      --text-3xl: 2rem;

      /* Spacing */
      --space-1: 0.25rem;
      --space-2: 0.5rem;
      --space-3: 0.75rem;
      --space-4: 1rem;
      --space-5: 1.25rem;
      --space-6: 1.5rem;
      --space-8: 2rem;
      --space-10: 2.5rem;
      --space-12: 3rem;
      --space-16: 4rem;

      /* Radii */
      --radius-sm: 0.375rem;
      --radius-md: 0.5rem;
      --radius-lg: 0.75rem;
      --radius-xl: 1rem;
    }
  </style>
  <style>
    /* Reset & Base */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: var(--font-sans);
      font-size: var(--text-base);
      line-height: 1.6;
      color: var(--text-primary);
      background: var(--bg-body);
      padding: var(--space-8) var(--space-4);
      max-width: 900px;
      margin: 0 auto;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    a { color: var(--severity-medium); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* Header */
    .report-header {
      background: var(--bg-elevated);
      color: var(--text-primary);
      padding: var(--space-8);
      border-radius: var(--radius-xl);
      margin-bottom: var(--space-8);
      border: 1px solid var(--border-strong);
    }
    .report-header h1 { font-size: var(--text-2xl); font-weight: 700; margin-bottom: var(--space-2); letter-spacing: -0.02em; }
    .report-meta { display: flex; flex-wrap: wrap; gap: var(--space-3); font-size: var(--text-sm); color: var(--text-secondary); }
    .report-meta span { background: var(--bg-active); padding: var(--space-1) var(--space-3); border-radius: var(--radius-sm); border: 1px solid var(--border-strong); }

    /* Sections */
    .section {
      background: var(--bg-surface);
      border-radius: var(--radius-lg);
      padding: var(--space-6) var(--space-8);
      margin-bottom: var(--space-6);
      border: 1px solid var(--border-strong);
    }
    .section h2 {
      font-size: var(--text-xl);
      color: var(--text-primary);
      border-bottom: 1px solid var(--border-default);
      padding-bottom: var(--space-2);
      margin-bottom: var(--space-4);
      font-weight: 600;
    }

    /* Score Strip — severity counts only, no PASS */
    .score-strip {
      display: flex;
      gap: var(--space-4);
      margin-bottom: var(--space-6);
    }
    .score-strip__item {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-2) var(--space-4);
      border-radius: var(--radius-md);
      border: 1px solid var(--border-default);
    }
    .score-strip__item--critical { background: var(--severity-critical-bg); border-color: var(--border-critical); }
    .score-strip__item--high { background: var(--severity-high-bg); border-color: var(--border-high); }
    .score-strip__item--medium { background: var(--severity-medium-bg); border-color: var(--border-medium); }
    .score-strip__item--low { background: var(--severity-low-bg); border-color: var(--border-low); }
    .score-strip__count {
      font-family: var(--font-mono);
      font-size: var(--text-2xl);
      font-weight: 700;
      line-height: 1;
    }
    .score-strip__item--critical .score-strip__count { color: var(--severity-critical); }
    .score-strip__item--high .score-strip__count { color: var(--severity-high); }
    .score-strip__item--medium .score-strip__count { color: var(--severity-medium); }
    .score-strip__item--low .score-strip__count { color: var(--severity-low); }
    .score-strip__label {
      font-size: var(--text-xs);
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--text-tertiary);
    }

    /* Severity Badges */
    .badge {
      display: inline-block;
      padding: var(--space-1) var(--space-2);
      border-radius: var(--radius-sm);
      font-size: var(--text-xs);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .badge-critical { background: var(--severity-critical-bg); color: var(--severity-critical); }
    .badge-high { background: var(--severity-high-bg); color: var(--severity-high); }
    .badge-medium { background: var(--severity-medium-bg); color: var(--severity-medium); }
    .badge-low { background: var(--severity-low-bg); color: var(--severity-low); }
    .badge-effort-low { background: rgba(34,197,94,0.08); color: #4ade80; }
    .badge-effort-medium { background: var(--severity-high-bg); color: var(--severity-high); }
    .badge-effort-high { background: var(--severity-critical-bg); color: var(--severity-critical); }
    .badge-impact-high { background: rgba(34,197,94,0.08); color: #4ade80; }
    .badge-impact-medium { background: var(--severity-medium-bg); color: var(--severity-medium); }
    .badge-impact-low { background: var(--severity-low-bg); color: var(--severity-low); }

    /* Evidence Tier Badges */
    .tier-badge {
      display: inline-flex;
      align-items: center;
      padding: 0.125rem 0.5rem;
      border-radius: var(--radius-sm);
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      line-height: 1.4;
    }
    .tier-badge--gold { background: var(--tier-gold-bg); color: var(--tier-gold); border: 1px solid rgba(251,191,36,0.20); }
    .tier-badge--silver { background: var(--tier-silver-bg); color: var(--tier-silver); border: 1px solid rgba(161,161,170,0.15); }
    .tier-badge--bronze { background: var(--tier-bronze-bg); color: var(--tier-bronze); border: 1px solid rgba(205,127,50,0.20); }

    /* Ethics Badge */
    .ethics-badge {
      display: inline-flex;
      padding: var(--space-1) var(--space-2);
      border-radius: var(--radius-sm);
      font-size: var(--text-xs);
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      background: var(--severity-critical-bg);
      color: var(--severity-critical);
      border: 1px solid var(--border-critical);
    }

    /* Tables */
    table { width: 100%; border-collapse: collapse; font-size: var(--text-base); }
    th { background: var(--bg-elevated); text-align: left; font-weight: 600; color: var(--text-secondary); }
    th, td { padding: 0.625rem 0.75rem; border-bottom: 1px solid var(--border-default); color: var(--text-secondary); }
    tr:last-child td { border-bottom: none; }

    /* Finding Cards — severity-led, no status display */
    .finding {
      background: var(--bg-surface);
      border: 1px solid var(--border-strong);
      border-radius: var(--radius-lg);
      margin-bottom: var(--space-4);
      overflow: hidden;
      padding: var(--space-4) var(--space-5);
    }
    .finding--critical { border-color: var(--border-critical); }
    .finding--high { border-color: var(--border-high); }
    .finding--medium { border-color: var(--border-medium); }
    .finding--low { border-color: var(--border-low); }
    .finding .finding-header { display: flex; gap: var(--space-3); align-items: center; margin-bottom: var(--space-2); }
    .finding .finding-body { font-size: var(--text-base); color: var(--text-secondary); line-height: 1.6; }
    .finding .finding-rec { margin-top: var(--space-2); font-size: var(--text-base); color: var(--text-primary); font-weight: 500; }
    .finding .finding-citation {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-3) 0;
      border-top: 1px solid var(--border-default);
      font-size: var(--text-xs);
      color: var(--text-tertiary);
      margin-top: var(--space-3);
    }
    .finding .finding-citation a {
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      color: var(--severity-medium);
      word-break: break-all;
    }
    .finding .finding-citation a:hover { text-decoration: underline; }

    /* Technical details (collapsible) — houses SOURCE */
    .finding details.finding-technical {
      border-top: 1px solid var(--border-default);
      margin-top: var(--space-3);
    }
    .finding details.finding-technical summary {
      padding: var(--space-3) 0;
      font-size: var(--text-sm);
      font-weight: 600;
      color: var(--text-secondary);
      cursor: pointer;
      list-style: none;
    }
    .finding details.finding-technical summary::before {
      content: '\25B6\00A0';
      font-size: 0.7em;
      display: inline-block;
      transition: transform 0.15s ease;
    }
    .finding details.finding-technical[open] summary::before {
      transform: rotate(90deg);
    }
    .finding .finding-tech-row {
      display: flex;
      gap: var(--space-2);
      padding: var(--space-1) 0;
      font-size: var(--text-sm);
    }
    .finding .finding-tech-label { font-weight: 600; color: var(--text-tertiary); min-width: 5rem; }
    .finding .finding-tech-value { color: var(--text-secondary); }

    /* Compare Mode */
    .compare-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-6); }

    /* Build Log Statuses */
    .status-done { color: #4ade80; font-weight: 600; }
    .status-adapted { color: var(--severity-high); font-weight: 600; }
    .status-stuck { color: var(--severity-critical); font-weight: 600; }
    .status-skipped { color: var(--severity-low); font-weight: 600; }

    /* Not Completed */
    .not-completed {
      text-align: center;
      padding: var(--space-8);
      color: var(--text-muted);
      font-style: italic;
    }

    /* Ethics Section */
    .ethics-section {
      background: var(--bg-surface);
      border-radius: var(--radius-lg);
      padding: var(--space-6) var(--space-8);
      margin-bottom: var(--space-6);
      border: 1px solid var(--border-strong);
    }
    .ethics-section h2 {
      font-size: var(--text-xl);
      font-weight: 600;
      color: var(--text-primary);
      border-bottom: 1px solid var(--border-default);
      padding-bottom: var(--space-2);
      margin-bottom: var(--space-4);
    }
    .ethics-section__clear {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-3) var(--space-4);
      border-radius: var(--radius-md);
      background: rgba(34,197,94,0.08);
      border: 1px solid rgba(34,197,94,0.15);
      color: #4ade80;
      font-size: var(--text-sm);
    }
    .ethics-section__check {
      font-size: var(--text-lg);
      font-weight: 700;
    }

    /* Footer */
    .report-footer {
      text-align: center;
      font-size: var(--text-xs);
      color: var(--text-muted);
      padding: var(--space-6) 0;
      border-top: 1px solid var(--border-default);
      margin-top: var(--space-8);
    }

    /* Print */
    @media print {
      :root {
        --bg-body: #ffffff;
        --bg-surface: #f8f8f8;
        --bg-elevated: #f0f0f2;
        --text-primary: #111111;
        --text-secondary: #444444;
        --text-tertiary: #666666;
        --text-muted: #999999;
        --border-default: #e0e0e0;
        --border-strong: #cccccc;
        --severity-critical: #dc2626;
        --severity-critical-bg: #fef2f2;
        --severity-high: #d97706;
        --severity-high-bg: #fffbeb;
        --severity-medium: #2563eb;
        --severity-medium-bg: #eff6ff;
        --severity-low: #6b7280;
        --severity-low-bg: #f3f4f6;
        --border-critical: #fca5a5;
        --border-high: #fcd34d;
        --border-medium: #93c5fd;
        --border-low: #d1d5db;
      }
      body { padding: 0; max-width: 100%; }
      .report-header { break-after: avoid; }
      .section, .ethics-section { break-inside: avoid; }
      .badge, .score-strip__item, .tier-badge { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      * { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
      @page { size: A4; margin: 1.5cm; }
    }

    /* Responsive */
    @media (max-width: 600px) {
      body { padding: var(--space-2); }
      .report-header { padding: var(--space-5); }
      .report-meta { flex-direction: column; gap: var(--space-2); }
      .section, .ethics-section { padding: var(--space-4); }
      .compare-grid { grid-template-columns: 1fr; }
      .score-strip { flex-wrap: wrap; }
      table { font-size: var(--text-xs); }
      th, td { padding: 0.4rem; }
    }
  </style>
</head>
<body>

  <!-- HEADER -->
  <div class="report-header">
    <h1>CRO Report</h1>
    <div class="report-meta">
      <span>ID: {{ENGAGEMENT_ID}}</span>
      <span>Date: {{DATE}}</span>
      <span>Type: {{TYPE}}</span>
      <span>Page: {{PAGE_URL}}</span>
      <span>Platform: {{PLATFORM}}</span>
    </div>
  </div>

  <!-- EXECUTIVE SUMMARY -->
  <div class="section">
    <h2>Executive Summary</h2>
    <div class="score-strip">
      <div class="score-strip__item score-strip__item--critical">
        <span class="score-strip__count">{{CRITICAL_COUNT}}</span>
        <span class="score-strip__label">Critical</span>
      </div>
      <div class="score-strip__item score-strip__item--high">
        <span class="score-strip__count">{{HIGH_COUNT}}</span>
        <span class="score-strip__label">High</span>
      </div>
      <div class="score-strip__item score-strip__item--medium">
        <span class="score-strip__count">{{MEDIUM_COUNT}}</span>
        <span class="score-strip__label">Medium</span>
      </div>
      <div class="score-strip__item score-strip__item--low">
        <span class="score-strip__count">{{LOW_COUNT}}</span>
        <span class="score-strip__label">Low</span>
      </div>
    </div>
    <p>{{EXECUTIVE_SUMMARY}}</p>
  </div>

  <!-- AUDIT FINDINGS (Standard Mode) -->
  <!-- {{SECTION:FINDINGS_START}} -->
  <div class="section">
    <h2>Audit Findings</h2>
    <!-- Each finding card: severity badge leads, NO status (PASS/FAIL/PARTIAL/SKIP) displayed.
         Evidence tier badge inline next to cited stats. Citation URLs as clickable links.
         SOURCE moved into collapsible "Technical details" section.
         Example structure per finding:
         <div class="finding finding--{{SEVERITY}}">
           <div class="finding-header">
             <span class="badge badge-{{SEVERITY}}">{{SEVERITY_LABEL}}</span>
             <strong>{{FINDING_TITLE}}</strong>
             <span class="tier-badge tier-badge--{{TIER}}">{{TIER_LABEL}}</span>
           </div>
           <div class="finding-body">{{OBSERVATION}}</div>
           <div class="finding-rec">{{RECOMMENDATION}}</div>
           <div class="finding-citation">
             <span>{{STUDY_AUTHOR}}, {{YEAR}}</span>
             <a href="{{CITATION_URL}}">{{CITATION_URL_DISPLAY}}</a>
           </div>
           <details class="finding-technical">
             <summary>Technical details</summary>
             <div class="finding-tech-row"><span class="finding-tech-label">Source:</span> <span class="finding-tech-value">{{SOURCE_TYPE}}</span></div>
             <div class="finding-tech-row"><span class="finding-tech-label">Section:</span> <span class="finding-tech-value">{{SECTION_SLUG}}</span></div>
           </details>
         </div>
    -->
    {{FINDINGS_CONTENT}}
  </div>
  <!-- {{SECTION:FINDINGS_END}} -->

  <!-- COMPARE MODE: YOUR FINDINGS -->
  <!-- {{SECTION:COMPARE_YOUR_START}} -->
  <div class="section">
    <h2>Your Page — Findings</h2>
    {{YOUR_FINDINGS_CONTENT}}
  </div>
  <!-- {{SECTION:COMPARE_YOUR_END}} -->

  <!-- COMPARE MODE: COMPETITOR FINDINGS -->
  <!-- {{SECTION:COMPARE_COMPETITOR_START}} -->
  <div class="section">
    <h2>Competitor Page — Findings</h2>
    {{COMPETITOR_FINDINGS_CONTENT}}
  </div>
  <!-- {{SECTION:COMPARE_COMPETITOR_END}} -->

  <!-- COMPARE MODE: GAP ANALYSIS -->
  <!-- {{SECTION:COMPARE_GAP_START}} -->
  <div class="section">
    <h2>Gap Analysis</h2>
    {{GAP_ANALYSIS_CONTENT}}
  </div>
  <!-- {{SECTION:COMPARE_GAP_END}} -->

  <!-- ACTION PLAN -->
  <!-- {{SECTION:PLAN_START}} -->
  <div class="section">
    <h2>Action Plan</h2>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>What</th>
          <th>Where</th>
          <th>Why</th>
          <th>Effort</th>
          <th>Impact</th>
          <th>Priority</th>
        </tr>
      </thead>
      <tbody>
        {{PLAN_ROWS}}
      </tbody>
    </table>
  </div>
  <!-- {{SECTION:PLAN_END}} -->

  <!-- REVIEW NOTES -->
  <!-- {{SECTION:REVIEW_START}} -->
  <div class="section">
    <h2>Review Notes</h2>
    <p><strong>Verdict:</strong> <span class="badge badge-{{VERDICT_CLASS}}">{{VERDICT}}</span></p>
    {{REVIEW_CONTENT}}
  </div>
  <!-- {{SECTION:REVIEW_END}} -->

  <!-- BUILD LOG -->
  <!-- {{SECTION:BUILD_START}} -->
  <div class="section">
    <h2>Implementation Log</h2>
    <table>
      <thead>
        <tr>
          <th>Step</th>
          <th>What</th>
          <th>Status</th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        {{BUILD_ROWS}}
      </tbody>
    </table>
  </div>
  <!-- {{SECTION:BUILD_END}} -->

  <!-- SCREENSHOT MODE NOTICE -->
  <!-- {{SECTION:SCREENSHOT_START}} -->
  <div class="section">
    <div class="not-completed">
      Recommendations Only — no source code was available for this audit.
      Build phase was skipped. Findings are based on visual analysis.
    </div>
  </div>
  <!-- {{SECTION:SCREENSHOT_END}} -->

  <!-- ETHICS COMPLIANCE — MANDATORY in every report, cannot be omitted -->
  <div class="ethics-section">
    <h2>Ethics Compliance</h2>
    {{ETHICS_CONTENT}}
    <!-- If no violations:
    <div class="ethics-section__clear">
      <span class="ethics-section__check">&#10003;</span>
      Ethics check: No dark patterns detected. Checked: urgency/scarcity signals, pricing transparency, review authenticity, choice architecture, subscription patterns.
    </div>
    -->
    <!-- If violations found: render each as a finding card with ethics-badge instead of severity badge -->
  </div>

  <!-- FOOTER -->
  <div class="report-footer">
    <p>Generated on {{GENERATED_DATE}} by CRO Plugin v{{VERSION}}</p>
    <p>This report is self-contained — no external resources are loaded.</p>
  </div>

</body>
</html>
