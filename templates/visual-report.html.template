<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Security-Policy" content="default-src 'none'; style-src 'unsafe-inline'; img-src data:; script-src 'none'; connect-src 'none'; frame-src 'none'; object-src 'none';">
  <title>CRO Visual Report — {{ENGAGEMENT_ID}}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
      line-height: 1.6;
      color: #1a1a2e;
      background: #f8f9fa;
      padding: 1rem;
      max-width: 1000px;
      margin: 0 auto;
    }

    /* Header Banner */
    .report-banner {
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
      color: #fff;
      padding: 1.5rem 2rem;
      border-radius: 12px;
      margin-bottom: 1.5rem;
      text-align: center;
    }
    .report-banner h1 { font-size: 1.1rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem; }
    .report-banner .warning { color: #f59e0b; font-size: 0.85rem; font-weight: 600; }
    .report-meta-bar { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; margin-top: 0.75rem; font-size: 0.8rem; opacity: 0.85; }
    .report-meta-bar span { background: rgba(255,255,255,0.15); padding: 0.2rem 0.6rem; border-radius: 4px; }

    /* Screenshot Sections */
    .screenshot-section { margin-bottom: 1.5rem; }
    .section-label {
      font-size: 0.75rem;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      padding: 0.5rem 0;
    }
    .screenshot-img {
      width: 100%;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      display: block;
    }

    /* CRO Callout Bars */
    .cro-callout {
      background: #ea580c;
      color: #fff;
      padding: 0.75rem 1rem;
      border-radius: 8px;
      margin: 0.75rem 0;
      font-size: 0.875rem;
      font-weight: 500;
      display: flex;
      align-items: flex-start;
      gap: 0.5rem;
    }
    .cro-callout .arrow { font-size: 1rem; flex-shrink: 0; }
    .cro-callout .source-badge {
      display: inline-block;
      background: rgba(255,255,255,0.25);
      padding: 0.1rem 0.4rem;
      border-radius: 3px;
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      margin-left: 0.5rem;
      flex-shrink: 0;
    }

    /* PASS Indicators */
    .pass-indicator {
      border-left: 3px solid #16a34a;
      padding: 0.4rem 0.75rem;
      margin: 0.5rem 0;
      font-size: 0.8rem;
      color: #166534;
      background: #f0fdf4;
      border-radius: 0 4px 4px 0;
    }

    /* Hidden Elements Section */
    .hidden-section {
      background: #fff;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      padding: 1.25rem;
      margin: 1.5rem 0;
    }
    .hidden-section h2 { font-size: 1rem; color: #1a1a2e; margin-bottom: 0.75rem; border-bottom: 2px solid #e2e8f0; padding-bottom: 0.5rem; }
    .hidden-item { padding: 0.5rem 0; border-bottom: 1px solid #f1f5f9; font-size: 0.875rem; }
    .hidden-item:last-child { border-bottom: none; }

    /* Footer */
    .report-footer {
      text-align: center;
      font-size: 0.75rem;
      color: #94a3b8;
      padding: 1.5rem 0;
      border-top: 1px solid #e2e8f0;
      margin-top: 2rem;
    }

    /* Print */
    @media print {
      body { padding: 0; background: #fff; max-width: 100%; }
      .report-banner { break-after: avoid; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .screenshot-section { break-inside: avoid; }
      .cro-callout { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      @page { size: A4 landscape; margin: 1cm; }
    }

    /* Responsive */
    @media (max-width: 600px) {
      body { padding: 0.5rem; }
      .report-banner { padding: 1rem; }
      .report-meta-bar { flex-direction: column; align-items: center; }
      .cro-callout { flex-direction: column; }
    }
  </style>
</head>
<body>

  <!-- HEADER BANNER -->
  <div class="report-banner">
    <h1>CRO Redesign Mockup</h1>
    <div class="warning">{{PAGE_URL}} — VISUAL GUIDE (NOT PRODUCTION CODE)</div>
    <div class="report-meta-bar">
      <span>ID: {{ENGAGEMENT_ID}}</span>
      <span>Date: {{DATE}}</span>
      <span>Platform: {{PLATFORM}}</span>
      <span>Clusters: {{CLUSTERS}}</span>
      <span>Source: {{SOURCE_MODE}}</span>
    </div>
  </div>

  <!-- SCREENSHOT SECTIONS WITH CALLOUTS -->
  {{SCREENSHOT_SECTIONS}}

  <!-- HIDDEN ELEMENTS -->
  <!-- {{SECTION:HIDDEN_START}} -->
  <div class="hidden-section">
    <h2>Hidden &amp; Dynamic Elements</h2>
    {{HIDDEN_FINDINGS}}
  </div>
  <!-- {{SECTION:HIDDEN_END}} -->

  <!-- ADDITIONAL FINDINGS (unmapped to screenshots) -->
  <!-- {{SECTION:ADDITIONAL_START}} -->
  <div class="hidden-section">
    <h2>Additional Findings</h2>
    {{ADDITIONAL_FINDINGS}}
  </div>
  <!-- {{SECTION:ADDITIONAL_END}} -->

  <!-- FOOTER -->
  <div class="report-footer">
    <p>Generated on {{GENERATED_DATE}} by CRO Plugin v{{VERSION}}</p>
    <p>This report is self-contained — no external resources are loaded.</p>
  </div>

</body>
</html>
