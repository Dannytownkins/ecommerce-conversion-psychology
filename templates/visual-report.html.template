<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Security-Policy" content="default-src 'none'; style-src 'unsafe-inline'; script-src 'unsafe-inline'; img-src data:; font-src data:;">
  <title>CRO Visual Report — {{ENGAGEMENT_ID}}</title>

  <!-- ============================================================
       ASSEMBLY INSTRUCTIONS (for workflows/visual-report.md):

       1. Copy ENTIRE contents of templates/font-embed.css here verbatim
          (do NOT read or interpret — just paste the raw CSS):
       ============================================================ -->
  <style>
    {{FONT_EMBED_CSS}}
  </style>

  <!-- ============================================================
       2. Copy the design tokens + base styles + all component CSS
          from templates/components.html (Section 1 through Section 14):
       ============================================================ -->
  <style>
    {{COMPONENT_STYLES}}
  </style>
</head>
<body class="report-body">

  <!-- [COMPONENT: report-header] -->
  {{REPORT_HEADER}}

  <!-- [COMPONENT: score-summary-strip] -->
  {{SCORE_STRIP}}

  <!-- [COMPONENT: split-layout with screenshot-panel + findings-panel] -->
  <div class="split-layout">

    <!-- LEFT: Sticky screenshot panel with SVG overlay markers -->
    <div class="screenshot-panel">
      {{SCREENSHOT_PANELS}}
    </div>

    <!-- RIGHT: Scrollable findings -->
    <div class="findings-panel">

      <!-- [COMPONENT: limitations-banner] (if screenshot-only or wireframe fallback) -->
      {{LIMITATIONS_BANNER}}

      <!-- [COMPONENT: finding-card] x N -->
      {{FINDING_CARDS}}

    </div>
  </div>

  <!-- [COMPONENT: ethics-compliance] (MANDATORY — never omit) -->
  {{ETHICS_SECTION}}

  <!-- [COMPONENT: export-footer] -->
  {{EXPORT_FOOTER}}

  <!-- [COMPONENT: scroll-sync-controller] (JavaScript — from components.html Section 11) -->
  {{SCROLL_SYNC_JS}}

</body>
</html>

<!--
  ============================================================
  ASSEMBLY NOTES:

  This template is a SKELETON. All HTML structure comes from
  templates/components.html. The workflow (workflows/visual-report.md)
  reads components.html, populates placeholders, and writes the
  completed HTML.

  DO NOT add inline CSS or custom HTML structure. All styling is
  defined in the component library's design tokens and component CSS.

  Required components from components.html:
  - Design tokens (Section 1)
  - Font embed reference (Section 2 — data from font-embed.css)
